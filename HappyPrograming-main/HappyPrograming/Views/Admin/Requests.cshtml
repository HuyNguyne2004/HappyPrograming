@model IEnumerable<HappyPrograming.Models.Request>

@{
    ViewData["Title"] = "Danh sách Request";
    int page = ViewBag.Page ?? 1;
    int pageSize = ViewBag.PageSize ?? 10;
    int total = ViewBag.Total ?? 0;
}

<h2 class="mb-4">Danh sách Request</h2>

<form asp-action="Requests" method="get" class="row g-3 mb-4">
    <div class="col-md-3">
        <input type="text" name="keyword" class="form-control" placeholder="Tìm tiêu đề hoặc username..." value="@ViewBag.Keyword" />
    </div>
    <div class="col-md-2">
        <select name="status" class="form-select">
            <option value="">-- Trạng thái --</option>
            <option value="Open" selected="@(ViewBag.Status == "Open")">Open</option>
            <option value="Processing" selected="@(ViewBag.Status == "Processing")">Processing</option>
            <option value="Closed" selected="@(ViewBag.Status == "Closed")">Closed</option>
        </select>
    </div>
    <div class="col-md-2">
        <input type="date" name="start" class="form-control" value="@ViewBag.Start" />
    </div>
    <div class="col-md-2">
        <input type="date" name="end" class="form-control" value="@ViewBag.End" />
    </div>
    <div class="col-md-3">
        <button type="submit" class="btn btn-primary">Lọc</button>
        <a asp-action="Requests" class="btn btn-secondary">Xóa lọc</a>
    </div>
</form>

<table class="table table-striped">
    <thead class="table-dark">
        <tr>
            <th>STT</th>
            <th>ID</th>
            <th>Người tạo</th>
            <th>Tiêu đề</th>
            <th>Trạng thái</th>
            <th>Ngày tạo</th>
        </tr>
    </thead>
    <tbody>
        @{
            int stt = (page - 1) * pageSize + 1;
        }
        @foreach (var req in Model)
        {
            <tr>
                <td>@stt</td>
                <td><a asp-action="RequestDetail" asp-route-id="@req.Id">@req.Id</a></td>
                <td>@req.Creator?.Username</td>
                <td>@req.Title</td>
                <td>
                    <span class="badge bg-@(req.Status == "Open" ? "warning" : req.Status == "Processing" ? "primary" : "success")">
                        @req.Status
                    </span>
                </td>
                <td>@req.CreatedAt?.ToString("dd/MM/yyyy HH:mm")</td>
            </tr>
            stt++;
        }
    </tbody>
</table>

@if (total > 0)
{
    <nav aria-label="Page navigation">
        <ul class="pagination justify-content-center">
            @for (int i = 1; i <= Math.Ceiling((double)total / pageSize); i++)
            {
                <li class="page-item @(i == page ? "active" : "")">
                    <a class="page-link" href="@Url.Action("Requests", new { keyword = ViewBag.Keyword, status = ViewBag.Status, start = ViewBag.Start, end = ViewBag.End, page = i })">@i</a>
                </li>
            }
        </ul>
    </nav>
}