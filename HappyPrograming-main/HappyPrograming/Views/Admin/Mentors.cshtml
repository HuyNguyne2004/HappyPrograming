@model IEnumerable<HappyPrograming.Models.Mentor>

@{
    ViewData["Title"] = "Danh sách Mentor";
    int page = ViewBag.Page ?? 1;
    int pageSize = ViewBag.PageSize ?? 10;
    int total = ViewBag.Total ?? 0;
    string keyword = ViewBag.Keyword ?? "";
}

<h2 class="mb-4">Danh sách Mentor</h2>

<form asp-action="Mentors" method="get" class="mb-4">
    <div class="input-group w-50">
        <input type="text" name="keyword" class="form-control" placeholder="Tìm theo tên, username hoặc nghề nghiệp..." value="@keyword" />
        <button type="submit" class="btn btn-primary">Tìm kiếm</button>
    </div>
</form>

<table class="table table-striped table-hover">
    <thead class="table-dark">
        <tr>
            <th>STT</th>
            <th>ID</th>
            <th>Họ và tên</th>
            <th>Username</th>
            <th>Nghề nghiệp</th>
            <th>Số request chấp nhận</th>
            <th>% Hoàn thành</th>
            <th>Đánh giá TB</th>
            <th>Trạng thái</th>
            <th>Hành động</th>
        </tr>
    </thead>
    <tbody>
        @{
            int stt = (page - 1) * pageSize + 1;
        }
        @foreach (var mentor in Model)
        {
            var acceptedCount = mentor.Requests?.Count(r => r.Status == "Processing" || r.Status == "Closed") ?? 0;
            var avgRating = mentor.Feedbacks?.Any() == true ? Math.Round(mentor.Feedbacks.Average(f => f.RatingStar), 1) : (double?)null;

            <tr>
                <td>@stt</td>
                <td>@mentor.Id</td>
                <td>@($"{mentor.User?.FirstName} {mentor.User?.LastName}")</td>
                <td>@mentor.User?.Username</td>
                <td>@mentor.Profession</td>
                <td>@acceptedCount</td>
                <td>—</td> <!-- % hoàn thành: thêm logic nếu bạn có trường theo dõi tiến độ -->
                <td>@(avgRating?.ToString("0.0") ?? "Chưa có")</td>
                <td>
                    <span class="badge @(mentor.User?.Status == "Active" ? "bg-success" : "bg-danger")">
                        @(mentor.User?.Status ?? "N/A")
                    </span>
                </td>
                <td>
                    <form asp-action="ToggleMentorStatus" asp-route-id="@mentor.User?.Id" method="post" style="display:inline;">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="btn btn-sm @(mentor.User?.Status == "Active" ? "btn-danger" : "btn-success")">
                            @(mentor.User?.Status == "Active" ? "Vô hiệu hóa" : "Kích hoạt")
                        </button>
                    </form>
                </td>
            </tr>
            stt++;
        }
    </tbody>
</table>

@if (total > 0)
{
    <nav aria-label="Page navigation">
        <ul class="pagination justify-content-center">
            @for (int i = 1; i <= Math.Ceiling((double)total / pageSize); i++)
            {
                <li class="page-item @(i == page ? "active" : "")">
                    <a class="page-link" href="@Url.Action("Mentors", new { keyword, page = i })">@i</a>
                </li>
            }
        </ul>
    </nav>
}