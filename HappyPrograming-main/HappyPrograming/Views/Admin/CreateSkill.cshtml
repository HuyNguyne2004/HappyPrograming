@model HappyPrograming.Models.Skill

@{
    ViewData["Title"] = "Thêm kỹ năng mới";
}

<h2>Thêm kỹ năng mới</h2>

<form asp-action="CreateSkill" method="post">
    <div class="mb-3">
        <label asp-for="Name" class="form-label">Tên kỹ năng <span class="text-danger">*</span></label>
        <input asp-for="Name" class="form-control" required />
        <span asp-validation-for="Name" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="Description" class="form-label">Mô tả</label>
        <textarea asp-for="Description" class="form-control" rows="3"></textarea>
    </div>

    <button type="submit" class="btn btn-primary">Thêm mới</button>
    <a asp-action="Skills" class="btn btn-secondary">Quay lại</a>
</form>