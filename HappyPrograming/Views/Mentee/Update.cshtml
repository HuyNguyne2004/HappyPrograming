@model HappyPrograming.Models.DTO.UpdateRequestDTO
@{
    var skills = ViewBag.Skills as List<HappyPrograming.Models.Skill>;
}

<div class="container mt-4">
    <h2>Cập nhật yêu cầu #@Model.Id</h2>
    <form asp-action="Update" method="post">
        <input type="hidden" asp-for="Id" />

        <div class="mb-3">
            <label class="form-label">Tiêu đề</label>
            <input asp-for="Title" class="form-control" />
        </div>

        <div class="mb-3">
            <label class="form-label">Kỹ năng</label>
            <div class="border p-3">
                @foreach (var skill in skills)
                {
                    <div class="form-check form-check-inline">
                        <input class="form-check-input" type="checkbox" name="skillIds" value="@skill.Id"
                               id="skill_@skill.Id"
                               @(Model.SkillIds.Contains(skill.Id) ? "checked" : "")>
                        <label class="form-check-label" for="skill_@skill.Id">@skill.Name</label>
                    </div>
                }
            </div>
        </div>

        <button type="submit" class="btn btn-success">Cập nhật</button>
    </form>
</div>