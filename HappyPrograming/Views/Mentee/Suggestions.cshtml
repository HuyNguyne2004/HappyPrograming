@model List<HappyPrograming.Models.DTO.MentorSuggestionDTO>

<div class="container mt-4">
    <h3>Mentor phù hợp cho yêu cầu của bạn</h3>
    <div class="row">
        @foreach (var mentor in Model)
        {
            <div class="col-md-4 mb-3">
                <div class="card shadow-sm">
                    <div class="card-body">
                        <h5 class="card-title">@mentor.FullName (@mentor.AccountName)</h5>
                        <p class="text-warning">Đánh giá: @mentor.AverageStar.ToString("0.0") ⭐</p>
                        <p class="small">Đang dạy: @mentor.CurrentRequests lớp</p>
                        <button onclick="openRateModal(@mentor.MentorId)" class="btn btn-primary btn-sm w-100">Đánh giá Mentor này</button>
                    </div>
                </div>
            </div>
        }
    </div>

    <div class="modal fade" id="rateModal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Đánh giá Mentor</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <input type="hidden" id="modalMentorId" />
                    <input type="hidden" id="modalRequestId" value="@ViewBag.RequestId" /> <div class="mb-3">
                        <label>Số sao</label>
                        <select id="modalStar" class="form-select">
                            <option value="5">5 sao - Rất tốt</option>
                            <option value="4">4 sao</option>
                            <option value="3">3 sao</option>
                            <option value="2">2 sao</option>
                            <option value="1">1 sao - Kém</option>
                        </select>
                    </div>
                    <div class="mb-3">
                        <label>Bình luận</label>
                        <textarea id="modalComment" class="form-control" rows="3"></textarea>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Hủy</button>
                    <button type="button" onclick="sendRating()" class="btn btn-primary">Lưu đánh giá</button>
                </div>
            </div>
        </div>
    </div>

    <script>
        function openRateModal(mentorId) {
            document.getElementById('modalMentorId').value = mentorId;
            new bootstrap.Modal(document.getElementById('rateModal')).show();
        }

        function sendRating() {
            const ratingData = {
                RequestId: parseInt(document.getElementById('modalRequestId').value),
                MentorId: parseInt(document.getElementById('modalMentorId').value),
                Star: parseInt(document.getElementById('modalStar').value),
                Comment: document.getElementById('modalComment').value
            };

            fetch('/Mentee/RateMentor', { // Đường dẫn tới Action ở bước 2
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(ratingData)
            })
            .then(res => res.json())
            .then(data => {
                if (data.success) {
                    alert(data.message);
                    location.reload(); // Load lại để thấy kết quả
                } else {
                    alert("Lỗi: " + data.message);
                }
            });
        }
    </script>
</div>

<div id="rateModal" class="modal fade" tabindex="-1">
</div>