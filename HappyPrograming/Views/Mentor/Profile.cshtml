@model HappyPrograming.Models.Mentor

<div class="profile-container">
    <h2>Mentor Profile: @Model.User.FirstName @Model.User.LastName</h2>
    <p>Chuyên môn: @Model.Profession</p>
    <p>Giới thiệu: @Model.ProfessionIntroduction</p>

    <hr />
    <h3>Đổi mật khẩu (NEW FLOW)</h3>

    @if (ViewBag.Error != null)
    {
        <p style="color:red">@ViewBag.Error</p>
    }
    @if (ViewBag.Success != null)
    {
        <p style="color:green">@ViewBag.Success</p>
    }

    <form asp-action="ChangePassword" method="post">
        <input type="hidden" name="userId" value="@Model.UserId" />
        <input type="password" name="oldPass" placeholder="Mật khẩu cũ" required /><br />
        <input type="password" name="newPass" placeholder="Mật khẩu mới" required /><br />
        <input type="password" name="confirm" placeholder="Xác nhận mật khẩu mới" required /><br />
        <button type="submit">Xác nhận đổi</button>
    </form>
</div>